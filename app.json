{
  "expo": {
    "name": "VoltEye",
    "slug": "volteye-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/volteye-logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/volteye-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#faf8ff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/volteye-logo.png",
        "backgroundColor": "#faf8ff"
      },
      "package": "com.wuel1.volteyemobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/volteye-logo.png"
    },
    "extra": {
      "eas": {
        "projectId": "59af84d3-13dd-46a6-880f-a1c5cfdaaa19"
      }
    }
  }
}
